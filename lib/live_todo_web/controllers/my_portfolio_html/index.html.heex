      <div class="flex-shrink-0 w-40 h-40 rounded-full overflow-hidden border-4 border-indigo-400 shadow-md">
        <img src="images/mustafa.jpg" alt="Mustafa Waheed Khan" class="w-full h-full object-cover">
      </div>
      <!-- Name & Title -->
